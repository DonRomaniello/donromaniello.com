---
import Base from '../layouts/Base.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog')).sort(
  (a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime()
);

const projects = await getCollection('projects');
---

<Base>
  <h1>Don Romaniello</h1>
  <p>Software engineer. Welcome to my corner of the internet.</p>

  {posts.length > 0 && (
    <section>
      <h2>Recent posts</h2>
      <ul class="post-list">
        {posts.slice(0, 5).map((post) => (
          <li>
            <a href={`/blog/${post.id}`}>{post.data.title}</a>
            <time>{post.data.date}</time>
          </li>
        ))}
      </ul>
    </section>
  )}

  {projects.length > 0 && (
    <section>
      <h2>Projects</h2>
      <ul class="project-list">
        {projects.map((project) => (
          <li>
            <a href={`/projects/${project.id}`}>{project.data.title}</a>
            <span>{project.data.description}</span>
          </li>
        ))}
      </ul>
    </section>
  )}
</Base>

<style>
  section {
    margin-top: 2rem;
  }

  .post-list, .project-list {
    list-style: none;
    padding: 0;
  }

  .post-list li, .project-list li {
    display: flex;
    flex-direction: column;
    margin-bottom: 0.75rem;
  }

  .post-list a, .project-list a {
    text-decoration: none;
    font-weight: 500;
  }

  .post-list time {
    color: var(--muted);
    font-size: 0.85rem;
  }

  .project-list span {
    color: var(--muted);
    font-size: 0.9rem;
  }
</style>
