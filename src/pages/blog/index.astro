---
import Base from '../../layouts/Base.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog')).sort(
  (a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime()
);
---

<Base title="Blog">
  <h1>Blog</h1>
  {posts.length === 0 ? (
    <p>No posts yet. Add <code>.md</code> files to <code>src/content/blog/</code>.</p>
  ) : (
    <ul class="post-list">
      {posts.map((post) => (
        <li>
          <a href={`/blog/${post.id}`}>{post.data.title}</a>
          {post.data.description && <span class="desc">{post.data.description}</span>}
          <time>{post.data.date}</time>
        </li>
      ))}
    </ul>
  )}
</Base>

<style>
  .post-list {
    list-style: none;
    padding: 0;
  }

  .post-list li {
    display: flex;
    flex-direction: column;
    margin-bottom: 1.25rem;
  }

  .post-list a {
    text-decoration: none;
    font-weight: 500;
    font-size: 1.1rem;
  }

  .desc {
    color: var(--muted);
    font-size: 0.9rem;
  }

  time {
    color: var(--muted);
    font-size: 0.85rem;
  }
</style>
