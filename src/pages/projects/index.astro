---
import Base from '../../layouts/Base.astro';
import { getCollection } from 'astro:content';

const projects = await getCollection('projects');
---

<Base title="Projects">
  <h1>Projects</h1>
  {projects.length === 0 ? (
    <p>No projects yet. Add <code>.md</code> files to <code>src/content/projects/</code>.</p>
  ) : (
    <ul class="project-list">
      {projects.map((project) => (
        <li>
          <a href={`/projects/${project.id}`}>{project.data.title}</a>
          <span class="desc">{project.data.description}</span>
          {project.data.tech && (
            <span class="tech">{project.data.tech.join(' · ')}</span>
          )}
        </li>
      ))}
    </ul>
  )}
</Base>

<style>
  .project-list {
    list-style: none;
    padding: 0;
  }

  .project-list li {
    display: flex;
    flex-direction: column;
    margin-bottom: 1.5rem;
  }

  .project-list a {
    text-decoration: none;
    font-weight: 500;
    font-size: 1.1rem;
  }

  .desc {
    color: var(--muted);
    font-size: 0.9rem;
  }

  .tech {
    color: var(--muted);
    font-size: 0.8rem;
    margin-top: 0.25rem;
  }
</style>
